# ──────────────────────────────────────────────────────────
# Themis Court Path — .gitignore
# ──────────────────────────────────────────────────────────
# Critical: this repo MUST NOT contain customer PII,
# secrets, credentials, or generated test artifacts that
# include real personal data.
# ──────────────────────────────────────────────────────────

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── Virtual environments ────────────────────────────────
venv/
ENV/
env/
.venv/
.env
.env.*
!.env.example

# ── IDE / editor ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Application generated output (CRITICAL — contains PII) ──
# Never commit anything that might contain real customer data
output/
outputs/
generated/
filings/
user_data/
**/output/
**/outputs/
**/generated/

# ── Test data with PII (CRITICAL) ───────────────────────
# Test JSON files often contain real names/SSNs/etc.
*intake.json
*intake*.json
test_data*.json
sample_data*.json
**/output/*.json
**/output/*.pdf
**/output/*.txt

# ── Real-name test files (CRITICAL — Spear family data) ─
Spear*
Speear*
*_vs_*.pdf
*_vs_*.json
*_vs_*.txt
*_Validation.txt

# ── Credentials, secrets, keys ──────────────────────────
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
secrets.yaml
secrets.yml
secrets.json
credentials.json
service-account*.json
gcp-key*.json
*-credentials.*
.netrc
.pgpass

# ── Cloud SDK ───────────────────────────────────────────
.gcloud/
gcloud-config/

# ── Database ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sql.gz
db_dumps/

# ── Logs ────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Backups and archives ────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.swp
backups/

# ── Screenshots (often capture credentials) ─────────────
Screenshot*
screenshot*
ScreenShot*
SCREENSHOT*
*.png.bak
# Allow specific marketing screenshots if needed by adding override later

# ── Scan output (PDF page renders for testing) ──────────
**/scan/
**/scans/
*_scan.png
pg[0-9][0-9].png
blank_*.png
*_check.png

# ── Build output ────────────────────────────────────────
dist/
build/
*.tgz
*.tar.gz
*.zip

# ── Docker ──────────────────────────────────────────────
.dockerignore.bak

# ── Node (in case we add JS tools later) ────────────────
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.npm
.yarn-integrity
package-lock.json.bak

# ── Temporary files ─────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── OS artifacts ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Project-specific exclusions ─────────────────────────
# Internal session quick-start files (not for public repo)
99_ARCHIVE/

# ── Allowlist (force-include important files) ───────────
# Use with caution — these override above patterns
!Petition_to_Establish_Child_Support.pdf
!Petition_to_Establish_Child_Support_NAVAJO.pdf
